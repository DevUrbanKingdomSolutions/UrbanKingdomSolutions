{
  "name": "production-crew-dashboard",
  "version": "1.7.52",
  "private": true,
  "type": "module",
  "description": "Entertainment production dashboard with Supabase auth and a Capacitor mobile foundation.",
  "scripts": {
    "cap:prepare": "node scripts/prepare-capacitor-web.mjs",
    "cap:check": "node scripts/native-readiness-check.mjs",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npm run cap:prepare && npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/camera": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/geolocation": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/push-notifications": "^8.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0"
  }
}
